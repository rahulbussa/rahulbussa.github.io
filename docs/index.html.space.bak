<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Rahul Bussa Portfolio, Javascript, Salesforce Frontend, LWC developer India, ">
    <meta name="keyword"
        content="Rahul Bussa, LWC, Salesforce UI, javascript developer, portfolio, javascript, developer">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta property="og:title" content="Rahul Bussa | Front end Developer">
    <meta property="og:description"
        content="JavaScript wizard, Rahul Bussa, Salesforce UI developer, LWC Developer, Aura Developer" />
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://rahulbussa.js.org/">
    <meta property="og:image" content="/archieve/favicon-32x32.fcc98fa1.png">
    <meta name="google-site-verification" content="3e9GJho3oU1TbA5iQvP1RAx7kA2G_nXG4inAfGcjQS0" />
    <link rel="manifest" href="/archieve/site.webmanifest">
    <link rel="apple-touch-icon" href="/archieve/icon.878d0521.png">
    <link rel="icon" type="image/png" href="/archieve/favicon-32x32.61ef6b08.png" />
    <link rel='shortcut icon' type='image/x-icon' href='/archieve//favicon.ico' />
    <title>Rahul Bussa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://www.google-analytics.com/">
    <link rel="stylesheet" href="./assets/css/style.css">
    <script src="https://unpkg.com/scrollreveal"></script>

</head>

<body>
    <div class="page">
        <header class="header" id="top">
            <nav class="nav">
                <a href="#top" class="nav__logo" aria-label="Rahul Bussa">Rahul Bussa</a>
                <button class="nav__toggle" type="button" aria-label="Open Navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <div class="nav__menu">
                    <a href="#home" class="nav__link">Home</a>
                    <a href="#about" class="nav__link">About</a>
                    <a href="#skills" class="nav__link">Skills</a>
                    <a href="#contact" class="nav__link">Contact</a>
                </div>
            </nav>
        </header>
        <main>
            <section class="hero section" id="home">
                <div class="hero__grid">
                    <div class="hero__content reveal">
                        <p class="eyebrow">Orbiting the web since 2013</p>
                        <h1>Hi, I am Rahul Bussa</h1>
                        <h2>Front End Developer</h2>
                        <p class="lead">Hello! My Name is Rahul Bussa. I am passionate Javascript developer based out of
                            Hyderabad, India</p>
                        <div class="hero__actions">
                            <a href="#contact" class="button">Contact Me</a>
                            <a href="#about" class="button button--ghost">Explore</a>
                        </div>
                        <div class="hero__socials">
                            <a aria-label="github" href="https://github.com/rahulbussa/" rel="noreferrer"
                                target="_blank">
                                GitHub
                            </a>
                            <a aria-label="twitter" href="https://twitter.com/rahulbussa2" rel="noreferrer"
                                target="_blank">
                                Twitter
                            </a>
                            <a aria-label="linkedIn" href="https://www.linkedin.com/in/rahul-bussa-6735464b/"
                                rel="noreferrer" target="_blank">
                                LinkedIn
                            </a>
                            <a aria-label="trailhead" href="https://trailblazer.me/id/rahulbussa" rel="noreferrer"
                                target="_blank">
                                Trailhead
                            </a>
                        </div>
                    </div>
                    <div class="hero__visual reveal">
                        <div class="planet">
                            <div class="planet__ring"></div>
                            <div class="planet__glow"></div>
                        </div>
                        <img class="astronaut-image" src="./assets/svg/astronaut.svg" alt="Astronaut waving smiling"
                            loading="lazy" />
                        <div class="comet comet--one"></div>
                        <div class="comet comet--two"></div>
                        <span class="mini-comet mini-comet--hero mini-comet--hero-one"></span>
                        <span class="mini-comet mini-comet--hero mini-comet--hero-two"></span>
                        <span class="mini-comet mini-comet--hero mini-comet--hero-three"></span>
                        <div class="hero__badge">
                            <span>Javascript</span>
                            <span>Salesforce Frontend</span>
                            <span>React</span>
                        </div>
                    </div>
                </div>
                <a class="scroll-indicator" href="#about" aria-label="Scroll to About">Scroll</a>
            </section>
            <section class="about section" id="about">
                <div class="section__title reveal">
                    <p class="eyebrow">About Me</p>
                    <h2>Builder of scalable experience</h2>
                </div>
                <p class="section__subtitle reveal">
                    I'm Full Stack JavaScript Developer with proven track record of building scalable, user-friendly web
                    and mobile applications. I bring a combination of technical expertise and problem-solving skills to
                    every project. My passion for clean, maintainable code and a commitment to user experience sets me
                    apart as a reliable developer.
                </p>
                <div class="about__grid">
                    <div class="about__card reveal">
                        <h3>10+</h3>
                        <p>Years experience</p>
                    </div>
                    <div class="about__card reveal">
                        <h3>50+</h3>
                        <p>Projects completed</p>
                    </div>
                    <div class="about__card reveal">
                        <h3>Based out of</h3>
                        <p>Hyderabad, India</p>
                    </div>
                </div>
                <div class="about__cta reveal">
                    <a href="./assets/RahulBussaResume.pdf" class="button">Download CV</a>
                </div>
            </section>
            <section class="skills section" id="skills">
                <div class="section__title reveal">
                    <p class="eyebrow">Skills</p>
                    <h2>My Technical Skills</h2>
                </div>
                <div class="skills__grid">
                    <div class="skill-group reveal">
                        <h3>Frontend Development</h3>
                        <p>More than 10 years</p>
                        <div class="skill">
                            <div class="skill__meta">
                                <span>JavaScript</span>
                                <span>90%</span>
                            </div>
                            <div class="skill__bar" style="--level: 90%"></div>
                        </div>
                        <div class="skill">
                            <div class="skill__meta">
                                <span>React</span>
                                <span>70%</span>
                            </div>
                            <div class="skill__bar" style="--level: 70%"></div>
                        </div>
                        <div class="skill">
                            <div class="skill__meta">
                                <span>Salesforce LWC</span>
                                <span>85%</span>
                            </div>
                            <div class="skill__bar" style="--level: 85%"></div>
                        </div>
                        <div class="skill-group reveal">
                            <h3>Backend Development</h3>
                            <p>More than 6 years</p>
                            <div class="skill">
                                <div class="skill__meta">
                                    <span>NodeJS</span>
                                    <span>70%</span>
                                </div>
                                <div class="skill__bar" style="--level: 70%"></div>
                            </div>
                            <div class="skill">
                                <div class="skill__meta">
                                    <span>Salesforce APEX</span>
                                    <span>65%</span>
                                </div>
                                <div class="skill__bar" style="--level: 65%"></div>
                            </div>
                        </div>
                        <div class="skill-group reveal">
                            <h3>Mobile Development</h3>
                            <p>More than 2 years</p>
                            <div class="skill">
                                <div class="skill__meta">
                                    <span>React Native</span>
                                    <span>70%</span>
                                </div>
                                <div class="skill__bar" style="--level: 70%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <section class="contact section" id="contact">
                <div class="section__title reveal">
                    <p class="eyebrow">Contact Me</p>
                    <h2>Get in touch</h2>
                </div>
                <div class="contact__grid">
                    <div class="contact__copy reveal">
                        <p>
                            Want to build something that feels out of this world? Send a message and I
                            will get back to you.
                        </p>
                        <div class="contact__stats">
                            <div>
                                <span>Github</span>
                                <a href="https://github.com/rahulbussa" target="_blank" rel="noreferrer">
                                    github.com/rahulbussa
                                </a>
                            </div>
                            <div>
                                <span>LinkedIn</span>
                                <a href="https://www.linkedin.com/in/rahul-bussa-6735464b/" rel="noreferrer"
                                    target="_blank">linkedin.com/in/rahul-bussa-6735464b</a>
                            </div>
                        </div>
                    </div>
                    <form class="contact__form reveal" action="#">
                        <label for="name">
                            Name
                            <input type="text" name="name" placeholder="Your Name">
                        </label>
                        <label for="email">
                            Email
                            <input type="email" name="email" placeholder="you@email.com">
                        </label>
                        <label for="message">
                            Message
                            <textarea name="message" placeholder="Tell me about your mission">
                        </label>
                        <button class="button" type="submit">Send Message</button>
                    </form>
                </div>
            </section>
        </main>
        <footer class="footer">
            <div>
                <h3>Rahul Bussa</h3>
                <p>Frontend Developer</p>
            </div>
            <div class="footer__links">
                <a href="#about">About</a>
                <a href="#skills">Skills</a>
                <a href="#contact">Contact</a>
            </div>
            <div class="footer__note">Made with love from India</div>
        </footer>
    </div>
    <script src="./assets/js/script.js"></script>
</body>
</html>